# .env.example
# Copy this file to .env and fill in your actual values
# NEVER commit .env to Git!

# ============ BOT CONFIG ============
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
DATABASE_PATH=gigs_archive.db
DEBUG_MODE=true

# ============ CHAT IDS ============
# Get these from @userinfobot or /chat command
MAIN_CHANNEL_ID=-1234567890123
MODERATION_CHAT_ID=-1234567890
SUMMARY_CHANNEL_ID=-1234567890123
TEST_CHANNEL_ID=-1234567890123

# ============ ADMIN IDS ============
# Your Telegram user ID(s) - comma separated
ADMIN_IDS=[1234567890,0987654321]
